#!/usr/bin/env bash

# --- Strict Mode Configuration ---
# Exit immediately if a command exits with a non-zero status
set -e
# Treat unset variables as an error
set -u
# Catch errors in pipelines (e.g., cmd1 | cmd2 fails if cmd1 fails)
set -o pipefail
# Disable globbing for safety (optional, but good for file handling)
set -f

# Detect input source
is_a_tty=
if [ -t 0 ]; then
    is_a_tty=1
fi

BA_AGENT_CONTEXT=$(mktemp)
BA_AGENT_TEMP_CONTEXT=$(mktemp)
BA_PATH=~/devel/bash-agent

response=
answer=

# --- LOGGING HELPER ---
# Simply redirects all parameters to stderr
log() {
    if [[ $is_a_tty == "1" ]]; then
        echo $@ >&2
    fi
}

# --- Cleanup / Signal Handling ---
# Run this when the script exits (normal or error)
cleanup() {
    rm $BA_AGENT_CONTEXT
    rm $BA_AGENT_TEMP_CONTEXT
}
trap cleanup EXIT

# --- Swap context ---
# Swap the file usage for contex/temp context
swap_context() {
    c=$BA_AGENT_CONTEXT
    BA_AGENT_CONTEXT=$BA_AGENT_TEMP_CONTEXT
    BA_AGENT_TEMP_CONTEXT=$c
}

call_llm_updatecontext_and_print() {
    response=$(cat $BA_AGENT_CONTEXT | $BA_PATH/ba-curl)

    answer=$(echo $response | jq '.choices[0].message | {role: .role, content: .content, tool_calls: .tool_calls}')

    jq '.messages += [ $ARGS.positional[0] ]' \
        $BA_AGENT_CONTEXT \
        --jsonargs "$answer" > $BA_AGENT_TEMP_CONTEXT
    swap_context

    if [[ $(echo $answer | jq -r '.content | length') != "0" ]]; then
        log ""
        echo $answer | jq -r '.content'
    fi
}

# --- Main Script Logic ---
main() {
    echo '{
        "tools": [],
        "messages": [{
            "role": "system",
            "content": "You are an helpful assistant with access to tools."
        }]
    }' > $BA_AGENT_CONTEXT

    for t in $(ls $BA_PATH/tools); do
        jq '.tools += [$ARGS.positional[0]]' $BA_AGENT_CONTEXT --jsonargs "$($BA_PATH/tools/$t -h)" > $BA_AGENT_TEMP_CONTEXT
        swap_context
    done

    answer="{}"

    # If the prompt is piped in, consume the entire stdin
    # and do a call
    if [[ ! $is_a_tty == "1" ]]; then
        jq '.messages += [{role: "user", content: $ARGS.positional[0] }]' \
            $BA_AGENT_CONTEXT \
            --args "$(cat)" > $BA_AGENT_TEMP_CONTEXT
        swap_context
        call_llm_updatecontext_and_print
    fi

    # --- MAIN SHELL LOOP ---
    while true
    do
        tool_calls=$(echo $answer | jq '.tool_calls | length')

        if [[ "$tool_calls" == "0" && $is_a_tty == "1" ]]; then
            # Read user prompt if there is no tool call
            # and it's running interactively
            log ""
            log "------ $PWD ------"
            read -r -e -p "> " prompt

            jq '.messages += [{role: "user", content: $ARGS.positional[0] }]' \
                $BA_AGENT_CONTEXT \
                --args "$prompt" > $BA_AGENT_TEMP_CONTEXT
            swap_context
        elif [[ "$tool_calls" == "0" ]]; then
            # Exit the non interactive execution
            exit 0
        else
            # Call all tools requested by the LLM
            while IFS= read -r line; do
                set -- $line
                name="$1"
                arguments="$2"
                tool_call_id="$3"

                log "Calling $name with $arguments"
                set +e
                result=$( \
                    echo $arguments | \
                    jq -r 'to_entries | map("-\(.key) \(.value)") | join(" ")' | \
                    xargs $BA_PATH/tools/$name 2>&1
                )
                exit_status=$?
                set -e

                if [ $exit_status -ne 0 ]; then
                    jq '.messages += [{
                        role: "tool",
                        tool_call_id: $ARGS.positional[0],
                        content: $ARGS.positional[1],
                        additional_info: {
                            failure_reason: $ARGS.positional[2],
                        }
                    }]' \
                    $BA_AGENT_CONTEXT \
                    --args "$tool_call_id" "$result" "Exit status: $exit_status" \
                    > $BA_AGENT_TEMP_CONTEXT
                else
                    jq '.messages += [{role: "tool", tool_call_id: $ARGS.positional[0], content: $ARGS.positional[1] }]' \
                    $BA_AGENT_CONTEXT \
                    --args "$tool_call_id" "$result" \
                > $BA_AGENT_TEMP_CONTEXT
                fi

                swap_context
            done < <(echo $answer | jq -r '.tool_calls[] | "\(.function.name) \(.function.arguments) \(.id)"')
        fi

        # Call the LLM with the new context
        call_llm_updatecontext_and_print
    done
}

# Run main function
main "$@"

