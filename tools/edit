#!/usr/bin/env bash

# show_help returns an OpenAI function definition, the engine will attach it to
# the chat context.
show_help() {
    echo '{
        "type": "function",
        "function": {
            "name": "edit",
            "description": "Applies a patch to a file. The content parameter must be a unified diff patch in standard format. Use this tool for making precise edits to existing files without rewriting the entire file.",
            "parameters": {
                "type": "object",
                "required": ["file", "content"],
                "properties": {
                    "file": {"type": "string", "description": "The path of the file to edit (relative or absolute path)."},
                    "content": {"type": "string", "description": "A unified diff patch to apply to the file. The patch should be in standard unified diff format with context lines."}
                }
            }
        }
}'

exit 0
}

# Mandatory infomode flag.
infomode=

# Parse options
while getopts hi opt
do
    case $opt in
        h) show_help;;
        i) infomode=1;;
        ?) exit 2;;
    esac
done

shift $((OPTIND - 1))

# Extract parameters
file=$(echo "$@" | jq -r '.file')
content=$(echo "$@" | jq -r '.content')

# Infomode allows the tool to customize its tool calling log message.
# Mandatory exit 0 for allowing the engine to ask the user for permission.
if [[ "$infomode" == "1" ]]; then
    echo EDIT $file >&2
    echo "Applying patch with $(echo "$content" | wc -l) lines..." >&2
    exit 0
fi

#=============================
# Your actual code goes here.
#=============================

# Apply patch with the following options:
# -p0: Don't strip any leading components from file paths (we provide full path)
# -q: Quiet mode (less verbose output)
# -f: Force apply (don't abort on conflicts, but still report)
# The patch command expects unified diff format

# Create a temporary file for the patch
patch_file=$(mktemp)
echo "$content" > "$patch_file"

# Apply the patch
# Using -p0 since we provide the exact file path
# The -q flag reduces verbosity, -f forces application
result=$(patch -p0 -q -f "$file" < "$patch_file" 2>&1)
exit_status=$?

# Clean up
rm -f "$patch_file"

if [ $exit_status -eq 0 ]; then
    echo "Patch applied successfully"
    exit 0
else
    echo "Failed to apply patch: $result"
    exit 1
fi
