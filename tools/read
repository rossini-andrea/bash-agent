#!/usr/bin/env bash

show_help() {
echo '{
      "type": "function",
      "function": {
        "name": "read",
        "description": "Reads the entire content of a file.",
        "parameters": {
          "type": "object",
          "required": ["p"],
          "properties": {
            "p": {"type": "string", "description": "The path of the file relative to the working directory, or an absolute path."}
          }
        }
      }
    }'

 exit 0
}

pflag=
path=
infomode=
# Parse options
while getopts p:hi opt
do
    case $opt in
    h)  show_help;;
    p)  pflag=1
        path="$OPTARG";;
    i)  infomode=1;;
    ?)  exit 2;;
    esac
done

# Check for --help flag separately (not handled by getopts)
if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    show_help
fi

if [[ "$infomode" == "1" ]]; then
    echo READ $path >&2
    exit 0
fi

cat $path

