# Auto detect text files and perform LF normalization
* text=auto

# Explicitly declare text files you want to always be normalized and converted
# to CRLF when checked out on Windows.
*.sh text eol=lf
*.bash text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.xml text eol=lf
*.csv text eol=lf
*.sql text eol=lf
Makefile text eol=lf

# Scripts should always have LF line endings
*.sh eol=lf
*.bash eol=lf

# Template files
*.tmpl text eol=lf
*.template text eol=lf

# Config files
*.env text eol=lf

# Ensure no CRLF gets into the repo
*.bat -text
*.cmd -text

